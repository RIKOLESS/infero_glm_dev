# INFERO db backend environment sample.
# Copy to .env or export in your shell before running start.bat / start_glm.py.
# Never commit real credentials.

# ---- Main brain (GLM-5.2 via Aliyun compatible OpenAI API) ------------------
# Either GLM_API_KEY (auto-prefixed with `Bearer `) OR GLM_AUTH_HEADER (raw).
GLM_API_KEY=your_glm_key_here
# GLM_AUTH_HEADER=Bearer your_full_authorization_header

# Optional: override model / upstream if you have a different deployment.
# GLM_MODEL=glm-5.2
# GLM_UPSTREAM=https://token-plan.cn-beijing.maas.aliyuncs.com/compatible-mode/v1/chat/completions

# ---- Vision copilot (Qwen 3.7-plus, for image observation only) -------------
# VISION_MODEL=qwen3.7-plus

# ---- luwang platform (real backend, optional in demo mode) ------------------
# LUWANG_BASE_URL=http://118.121.196.98:8888
# LUWANG_TOKEN=your_luwang_login_token_here

# ---- WeatherAdapter operating mode -----------------------------------------
# auto : try luwang first, fall back to data/samples/*.json on failure (default)
# live : only real luwang; failures propagate as errors (needs LUWANG_TOKEN)
# demo : never touch luwang, always return data/samples/*.json
#        --> use this for judge review / offline demo
WEATHER_MODE=auto

# ---- Server ---------------------------------------------------------------
# INFERO_PORT=8000
